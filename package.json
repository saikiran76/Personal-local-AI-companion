{
  "name": "desktop-companion",
  "version": "0.1.0",
  "description": "AI-powered desktop companion that runs locally",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "vite build && electron-builder --win",
    "electron:build:dir": "vite build && electron-builder --win --dir"
  },
  "dependencies": {
    "@react-three/fiber": "^8.17.10",
    "@shadergradient/react": "^2.4.11",
    "camera-controls": "^3.1.2",
    "electron-store": "^10.0.0",
    "geist": "^1.7.2",
    "lucide-react": "^1.23.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "^0.185.1",
    "three-stdlib": "^2.36.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/three": "^0.185.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.0.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "vite": "^6.0.0",
    "wait-on": "^8.0.0"
  },
  "build": {
    "appId": "com.desktop-companion.app",
    "productName": "Luna",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "extraResources": [
      {
        "from": "backend/dist/backend.exe",
        "to": "backend.exe"
      },
      {
        "from": "backend/dist/voice_stt",
        "to": "voice_stt"
      }
    ],
    "win": {
      "target": [
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "include": null,
      "perMachine": true
    }
  },
  "overrides": {
    "react-reconciler": "0.29.0"
  }
}
